# .env.example — copie para .env e preencha os valores

# LLM (opcional — sistema funciona sem esta chave em modo offline)
ANTHROPIC_API_KEY=

# Caminhos (ajuste se sua estrutura for diferente)
AFIS_DB_PATH=../AFIS/afis_finance.db
AXIS_DB_PATH=../AXIS/axis_tax.db

# OCR (Tesseract)
# TESSERACT_CMD=/usr/bin/tesseract    # Linux/Mac
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe   # Windows
TESSERACT_CMD=tesseract

# E-mail para dunning (opcional — EMAIL_DRY_RUN=true por padrão)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_DRY_RUN=true    # IMPORTANTE: mude para false APENAS quando pronto para envio real

# Dados da empresa (usados nos templates de dunning)
# Configure via dashboard ou diretamente aqui
# COMPANY_NAME=
# COMPANY_EMAIL=

# Thresholds de reconciliação
AUTO_APPROVE_THRESHOLD=0.90  # confidence >= 0.90 → auto-aprovado
HUMAN_REVIEW_THRESHOLD=0.60  # confidence < 0.60 → revisão manual obrigatória

# Dunning (dias após vencimento por estágio)
DUNNING_STAGE1_DAYS=7
DUNNING_STAGE2_DAYS=15
DUNNING_STAGE3_DAYS=30
DUNNING_STAGE4_DAYS=45

# Forecast
DSO_TARGET_DAYS=30            # meta de DSO em dias
DSO_FORECAST_HORIZON=90       # dias de projeção

# Servidor
HOST=127.0.0.1
PORT=8002
DEBUG=false

# Updated parameters mapping

